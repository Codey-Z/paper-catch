# paper-catch 环境变量模板
# 复制此文件到 ~/.config/paper-fetch/.env 并修改

# Crossref 礼貌池邮箱（必填，影响 Wiley/Science/PNAS/MDPI 等多个 provider 的全文获取）
CROSSREF_MAILTO=your-email@example.com

# CloakBrowser 设置（可选）
CLOAKBROWSER_HEADLESS=true
# CLOAKBROWSER_BINARY_PATH=
# CLOAKBROWSER_TIMEOUT_MS=120000

# Elsevier 全文 API Key（可选）
# ELSEVIER_API_KEY=

# 下载目录（可选，默认使用 XDG_DATA_HOME）
# PAPER_FETCH_DOWNLOAD_DIR=
